# Copia este archivo como ".env" y rellena los valores.
# El .env real NO se sube al repositorio (está en .gitignore).

# Clave API de Resend (https://resend.com -> API Keys). Obligatoria para el formulario.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Remitente de los emails.
# - Sin dominio verificado (para empezar): Makeable <onboarding@resend.dev>
# - Con dominio verificado en Resend:      Makeable <presupuestos@makeable.es>
RESEND_FROM=Makeable <onboarding@resend.dev>
