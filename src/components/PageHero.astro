---
import Button from './Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  align?: 'left' | 'center';
}
const { eyebrow, title, text, primaryCta, secondaryCta, align = 'left' } = Astro.props;
---

<section class="page-hero podium-pattern">
  <div class:list={['container', 'page-hero__inner', { 'is-center': align === 'center' }]}>
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1 class="page-hero__title">{title}</h1>
    {text && <p class="lead page-hero__text">{text}</p>}
    {
      (primaryCta || secondaryCta) && (
        <div class="page-hero__actions">
          {primaryCta && (
            <Button href={primaryCta.href} variant="primary" size="lg">
              {primaryCta.label}
            </Button>
          )}
          {secondaryCta && (
            <Button href={secondaryCta.href} variant="outline" size="lg">
              {secondaryCta.label}
            </Button>
          )}
        </div>
      )
    }
  </div>
</section>

<style>
  .page-hero {
    padding-block: clamp(3rem, 7vw, 5.5rem);
    border-bottom: 1px solid var(--border);
  }
  .page-hero__inner {
    max-width: 62ch;
  }
  .page-hero__inner.is-center {
    max-width: 68ch;
    margin-inline: auto;
    text-align: center;
  }
  .page-hero__title {
    font-size: var(--fs-h1);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .page-hero__text {
    margin-top: 1.1rem;
  }
  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }
  .is-center .page-hero__actions {
    justify-content: center;
  }
</style>
