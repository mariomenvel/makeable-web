---
/**
 * Placeholder on-brand para la galería mientras no hay foto real.
 * Muestra el patrón del podio con una etiqueta.
 */
interface Props {
  label?: string;
  ratio?: string; /* p.ej. '4 / 5', '1 / 1' */
  class?: string;
}
const { label = 'Diseño Makeable', ratio = '4 / 5', class: className = '' } = Astro.props;
---

<div class={`ph podium-pattern ${className}`} style={`aspect-ratio:${ratio};`}>
  <div class="ph__inner">
    <svg width="46" height="46" viewBox="0 0 100 100" fill="none" aria-hidden="true">
      <rect width="100" height="100" rx="24" fill="var(--blue)" />
      <g fill="#fff">
        <rect x="22" y="52" width="14" height="26" rx="3" />
        <rect x="43" y="30" width="14" height="48" rx="3" />
        <rect x="64" y="44" width="14" height="34" rx="3" />
      </g>
    </svg>
    <span>{label}</span>
  </div>
</div>

<style>
  .ph {
    width: 100%;
    border-radius: var(--radius);
    border: 1px dashed var(--blue);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .ph__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--blue-700);
    font-weight: 500;
    font-size: var(--fs-small);
    text-align: center;
    padding: 1rem;
  }
</style>
